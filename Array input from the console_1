#include <iostream>
#include <Windows.h>

int main() 
{
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int size_array;

    std::cout << "Введите размер массива: ";
    std::cin >> size_array;

    int* array = new int[size_array];

    for (int i = 0; i < size_array; i++) 
    {
        std::cout << "array[" << i << "] = ";
        std::cin >> array[i];
    }

    std::cout << "Введённый массив: ";

    for (int i = 0; i < size_array; i++) 

    {
        std::cout << array[i];
        if (i < size_array - 1) {
            std::cout << " ";
        }
    }

    std::cout << std::endl;

    delete[] array;

    return EXIT_SUCCESS;
}
