#include <iostream>
#include <Windows.h>


double* create_array(int size_array)
{
    double* arr = new double[size_array]();
    return arr;
}

int main() 
{
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int size_arr;

    std::cout << "Введите размер массива: ";
    std::cin >> size_arr;

    double* array = create_array(size_arr);

    std::cout << "Массив: ";
    for (int i = 0; i < size_arr; i++) {
        std::cout << array[i] << " ";
    }
    std::cout << std::endl;

    delete[] array;

    return EXIT_SUCCESS;
}
